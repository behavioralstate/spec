{
  "bsp": {
    "version": "{{BSP_VERSION}}",
    "authentication": {
      "type": "bearer",
      "scheme": "Bearer",
      "docs": "https://docs.example.com/authentication"
    },
    "tenants": {
      "manifest": "https://api.example.com/.well-known/bsp/{tenantId}"
    },
    "services": {
      "io.bsp.agents": {
        "version": "{{BSP_VERSION}}",
        "description": "Platform-level routing for the multi-tenant host",
        "spec": "https://behavioralstate.io/specs/agents",
        "http": {
          "endpoint": "https://api.example.com/"
        }
      }
    },
    "capabilities": []
  }
}
