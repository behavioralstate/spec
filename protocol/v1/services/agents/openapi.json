        "summary": "Pause a running agent",
        "tags": ["Agent Lifecycle"],
        "responses": {
          "204": { "description": "Agent paused" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": {
            "description": "Agent not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "../../schemas/error.json" }
              }
            }
          }
        }
      }
    },
    "/agents/{id}/resume": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": { "type": "string" },
          "description": "Agent identifier"
        }
      ],
      "post": {
        "operationId": "resumeAgent",
        "summary": "Resume a paused agent",
        "tags": ["Agent Lifecycle"],
        "responses": {
          "204": { "description": "Agent resumed" },
