    { "name": "Event Delivery", "description": "io.oap.agents.events — Send events, list recent events" },
    { "name": "Command Log", "description": "io.oap.agents.commands — List produced commands" },
    { "name": "Agent Memory", "description": "io.oap.agents.memory — View agent memory state" }
  ],
