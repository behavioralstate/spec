                "schema": { "$ref": "../../schemas/error.json" }
              }
            }
          }
        }
      }
    },
    "/events": {
      "post": {
        "operationId": "sendEvent",
        "summary": "Send an event to the runtime",
        "description": "The runtime routes the event to matching agents asynchronously.",
        "tags": ["Event Delivery"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "../../schemas/agents/events.json#/$defs/event"
              }
            }
          }
        },
        "responses": {
          "202": { "description": "Event accepted for processing" },
          "400": {
            "description": "Invalid event",
            "content": {
              "application/json": {
                "schema": { "$ref": "../../schemas/error.json" }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      },
      "get": {
        "operationId": "listEvents",
        "summary": "List recent events",
        "tags": ["Event Delivery"],
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Filter by event type"
          }
        ],
        "responses": {
          "200": {
            "description": "List of recent events",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../../schemas/agents/events.json#/$defs/eventList"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/commands": {
      "get": {
        "operationId": "listCommands",
        "summary": "List recently produced commands",
        "tags": ["Command Log"],
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Filter by command type"
          },
          {
            "name": "agentId",
            "in": "query",
            "schema": { "type": "string" },
            "description": "Filter by agent ID"
          }
        ],
        "responses": {
          "200": {
            "description": "List of recent commands",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../../schemas/agents/commands.json#/$defs/commandList"
                }
              }
            }
          },
          "401": { "$ref": "#/components/responses/Unauthorized" }
        }
      }
    },
    "/agents/{id}/memory": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "schema": { "type": "string" },
          "description": "Agent identifier"
        }
      ],
      "get": {
        "operationId": "getAgentMemory",
        "summary": "Get current memory state for an agent",
        "description": "The memory response body is opaque — different runtimes return different formats.",
        "tags": ["Agent Memory"],
        "responses": {
          "200": {
            "description": "Agent memory state",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "../../schemas/agents/memory.json#/$defs/agentMemory"
                }
